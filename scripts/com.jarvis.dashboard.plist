    <string>com.jarvis.dashboard</string>

    <key>WorkingDirectory</key>
    <string>/Users/parthee/Desktop/Claude/projekter/jarvis</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/npm</string>
        <string>start</string>
